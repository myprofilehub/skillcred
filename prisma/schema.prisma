generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String             @id @default(cuid())
  name                       String?
  email                      String?            @unique
  username                   String?            @unique
  mobile                     String?            @unique
  password                   String?
  emailVerified              DateTime?
  image                      String?
  role                       UserRole           @default(STUDENT)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  emailNotifications         Boolean            @default(true)
  projectUpdateNotifications Boolean            @default(true)
  forcePasswordChange        Boolean            @default(false)
  lmsEmail                   String?            @unique
  accounts                   Account[]
  attendanceRecords          AttendanceRecord[]
  hrProfile                  HRProtocol?
  investorProfile            Investor?
  mentorProfile              Mentor?
  receivedMessages           Message[]          @relation("ReceivedMessages")
  sentMessages               Message[]          @relation("SentMessages")
  notifications              Notification[]
  payments                   Payment[]
  sessions                   Session[]
  studentProfile             Student?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Student {
  id                String                 @id @default(cuid())
  userId            String                 @unique
  college           String?
  stream            String?
  year              String?
  bio               String?
  githubUrl         String?
  linkedinUrl       String?
  subscription      SubscriptionTier       @default(FREE)
  hrVisibile        Boolean                @default(false)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  patEligible       Boolean                @default(false)
  enrollments       Enrollment[]
  hrViews           HRView[]
  interviewRequests InterviewRequest[]
  jobApplications   JobApplication[]
  lessonProgress    LessonProgress[]
  pitchRequests     PitchRequest[]
  portfolio         Portfolio?
  assignments       ProjectAssignment[]
  projectShowcases  ProjectShowcase[]
  assessmentResults Result[]
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendedWorkshops WorkshopRegistration[]
}

model Mentor {
  id               String              @id @default(cuid())
  userId           String              @unique
  specialization   String?
  bio              String?
  availability     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  batches          Batch[]
  assignedStudents Enrollment[]        @relation("MentorEnrollments")
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions         MentorshipSession[]
  recommendations  Recommendation[]
  reviews          Review[]
  leadingTracks    Track[]             @relation("TrackLead")
}

model HRProtocol {
  id                String             @id @default(cuid())
  userId            String             @unique
  company           String
  position          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewedProfiles    HRView[]
  interviewRequests InterviewRequest[]
  jobs              Job[]
}

model Track {
  id               String               @id @default(cuid())
  title            String
  slug             String               @unique
  description      String
  icon             String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  defaultMentorId  String?
  assessments      Assessment[]
  batches          Batch[]
  courses          Course[]
  curriculumPhases CurriculumPhase[]
  students         Enrollment[]
  projects         Project[]
  catalogProjects  ProjectCatalogItem[]
  recordings       Recording[]
  defaultMentor    Mentor?              @relation("TrackLead", fields: [defaultMentorId], references: [id])
}

model CurriculumPhase {
  id          String              @id @default(cuid())
  trackId     String
  phaseNumber Int
  title       String
  weekStart   Int
  weekEnd     Int
  description String?
  track       Track               @relation(fields: [trackId], references: [id])
  sessions    CurriculumSession[]

  @@unique([trackId, phaseNumber])
}

model CurriculumSession {
  id            String          @id @default(cuid())
  phaseId       String
  sessionNumber Int
  title         String
  objectives    String[]
  activities    String[]
  deliverables  String[]
  keyTech       String[]
  duration      Int             @default(120)
  phase         CurriculumPhase @relation(fields: [phaseId], references: [id])

  @@unique([phaseId, sessionNumber])
}

model ProjectCatalogItem {
  id              String              @id @default(cuid())
  trackId         String
  name            String
  tagline         String
  description     String?
  difficulty      Int                 @default(2)
  coreFeatures    String[]
  conceptsCovered Json?
  startupAngle    String?
  isActive        Boolean             @default(true)
  addedBy         String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  batches         Batch[]
  assignments     ProjectAssignment[]
  track           Track               @relation(fields: [trackId], references: [id])
}

model Enrollment {
  id              String           @id @default(cuid())
  studentId       String
  trackId         String
  mentorId        String?
  status          EnrollmentStatus @default(ACTIVE)
  progress        Int              @default(0)
  certIssued      Boolean          @default(false)
  certUrl         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  batchId         String?
  programDuration String           @default("8-week")
  couponCode      String?
  batch           Batch?           @relation(fields: [batchId], references: [id])
  mentor          Mentor?          @relation("MentorEnrollments", fields: [mentorId], references: [id])
  student         Student          @relation(fields: [studentId], references: [id])
  track           Track            @relation(fields: [trackId], references: [id])

  @@unique([studentId, trackId])
}

model Batch {
  id          String             @id @default(cuid())
  trackId     String
  projectId   String
  mentorId    String?
  name        String
  status      BatchStatus        @default(OPEN)
  maxStudents Int                @default(20)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  mentor      Mentor?            @relation(fields: [mentorId], references: [id])
  project     ProjectCatalogItem @relation(fields: [projectId], references: [id])
  track       Track              @relation(fields: [trackId], references: [id])
  students    Enrollment[]
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  amount          Float
  currency        String        @default("INR")
  status          PaymentStatus @default(PENDING)
  provider        String        @default("RAZORPAY")
  transactionId   String?
  trackId         String?
  projectId       String?
  batchId         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  programDuration String?
  couponCode      String?
  user            User          @relation(fields: [userId], references: [id])
}

model Project {
  id             String              @id @default(cuid())
  trackId        String
  title          String
  description    String
  level          String
  order          Int
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  skills         String[]
  portfolioItems PortfolioProject[]
  track          Track               @relation(fields: [trackId], references: [id])
  assignments    ProjectAssignment[]
}

model ProjectAssignment {
  id               String              @id @default(cuid())
  studentId        String
  projectId        String
  status           ProjectStatus       @default(NOT_STARTED)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  catalogProjectId String?
  catalogProject   ProjectCatalogItem? @relation(fields: [catalogProjectId], references: [id])
  project          Project             @relation(fields: [projectId], references: [id])
  student          Student             @relation(fields: [studentId], references: [id])
  submissions      Submission[]

  @@unique([studentId, projectId])
}

model Submission {
  id           String            @id @default(cuid())
  assignmentId String
  githubLink   String?
  files        String?
  notes        String?
  createdAt    DateTime          @default(now())
  reviews      Review[]
  assignment   ProjectAssignment @relation(fields: [assignmentId], references: [id])
}

model Review {
  id           String     @id @default(cuid())
  submissionId String
  mentorId     String
  verified     Boolean
  feedback     String?
  rating       Int?
  createdAt    DateTime   @default(now())
  mentor       Mentor     @relation(fields: [mentorId], references: [id])
  submission   Submission @relation(fields: [submissionId], references: [id])
}

model Course {
  id          String         @id @default(cuid())
  trackId     String
  title       String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  track       Track          @relation(fields: [trackId], references: [id])
  modules     CourseModule[]
}

model CourseModule {
  id       String   @id @default(cuid())
  courseId String
  title    String
  order    Int
  course   Course   @relation(fields: [courseId], references: [id])
  lessons  Lesson[]
}

model Lesson {
  id         String           @id @default(cuid())
  moduleId   String
  title      String
  type       LessonType
  contentUrl String?
  duration   Int?
  module     CourseModule     @relation(fields: [moduleId], references: [id])
  progress   LessonProgress[]
}

model LessonProgress {
  id        String   @id @default(cuid())
  lessonId  String
  studentId String
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, lessonId])
}

model MentorshipSession {
  id          String        @id @default(cuid())
  mentorId    String
  studentId   String?
  startTime   DateTime
  endTime     DateTime
  status      SessionStatus @default(SCHEDULED)
  meetingLink String?
  mentor      Mentor        @relation(fields: [mentorId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  type      String?
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Assessment {
  id           String   @id @default(cuid())
  trackId      String
  title        String
  type         String
  totalMarks   Int
  passingMarks Int
  createdAt    DateTime @default(now())
  track        Track    @relation(fields: [trackId], references: [id])
  results      Result[]
}

model Result {
  id           String     @id @default(cuid())
  assessmentId String
  studentId    String
  score        Int
  passed       Boolean
  feedback     String?
  createdAt    DateTime   @default(now())
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  student      Student    @relation(fields: [studentId], references: [id])
}

model Portfolio {
  id              String             @id @default(cuid())
  studentId       String             @unique
  bio             String?
  skills          String[]
  resumeUrl       String?
  linkedinUrl     String?
  githubUrl       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  education       Json?
  experience      Json?
  headline        String?
  isPublic        Boolean            @default(false)
  isUnlocked      Boolean            @default(false)
  patPassedAt     DateTime?
  publicSlug      String?            @unique
  student         Student            @relation(fields: [studentId], references: [id])
  projects        PortfolioProject[]
  recommendations Recommendation[]
}

model PortfolioProject {
  id          String    @id @default(cuid())
  portfolioId String
  projectId   String?
  createdAt   DateTime  @default(now())
  description String
  feedback    String?
  githubUrl   String?
  grade       Int?
  imageUrl    String?
  projectUrl  String?
  skills      String[]
  title       String
  updatedAt   DateTime  @updatedAt
  verifiedBy  String?
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
}

model Recommendation {
  id          String    @id @default(cuid())
  portfolioId String
  mentorId    String
  content     String?
  issuedAt    DateTime  @default(now())
  fileUrl     String?
  mentor      Mentor    @relation(fields: [mentorId], references: [id])
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])
}

model HRView {
  id        String     @id @default(cuid())
  hrId      String
  studentId String
  viewedAt  DateTime   @default(now())
  hr        HRProtocol @relation(fields: [hrId], references: [id])
  student   Student    @relation(fields: [studentId], references: [id])
}

model InterviewRequest {
  id        String     @id @default(cuid())
  hrId      String
  studentId String
  status    String     @default("PENDING")
  message   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  hr        HRProtocol @relation(fields: [hrId], references: [id])
  student   Student    @relation(fields: [studentId], references: [id])
}

model GoogleClassroom {
  id                 String              @id @default(cuid())
  googleCourseId     String              @unique
  meetLink           String
  mentorId           String
  updatedAt          DateTime            @updatedAt
  attendanceSessions AttendanceSession[]
  recordings         Recording[]
}

model AttendanceSession {
  id                String             @id @default(cuid())
  googleCourseId    String
  googleClassroomId String?
  startTime         DateTime
  endTime           DateTime
  durationMinutes   Int
  meetCode          String?
  verifiedBy        String
  createdAt         DateTime           @default(now())
  records           AttendanceRecord[]
  googleClassroom   GoogleClassroom?   @relation(fields: [googleClassroomId], references: [id])

  @@unique([googleCourseId, startTime])
}

model AttendanceRecord {
  id        String            @id @default(cuid())
  sessionId String
  studentId String
  status    AttendanceStatus  @default(PRESENT)
  createdAt DateTime          @default(now())
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User              @relation(fields: [studentId], references: [id])
}

model Recording {
  id                String           @id @default(cuid())
  title             String
  description       String?
  url               String
  type              RecordingType
  meetCode          String?
  googleClassroomId String?
  trackId           String?
  isPublic          Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  googleClassroom   GoogleClassroom? @relation(fields: [googleClassroomId], references: [id])
  track             Track?           @relation(fields: [trackId], references: [id])
}

model Job {
  id           String           @id @default(cuid())
  hrId         String
  title        String
  description  String
  location     String
  type         JobType          @default(FULL_TIME)
  skills       String[]
  salary       String?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  hr           HRProtocol       @relation(fields: [hrId], references: [id])
  applications JobApplication[]
}

model JobApplication {
  id          String            @id @default(cuid())
  jobId       String
  studentId   String
  status      ApplicationStatus @default(APPLIED)
  coverLetter String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student     Student           @relation(fields: [studentId], references: [id])

  @@unique([jobId, studentId])
}

model Investor {
  id              String         @id @default(cuid())
  userId          String         @unique
  company         String
  position        String
  bio             String?
  focusAreas      String[]
  investmentRange String?
  portfolioUrl    String?
  linkedinUrl     String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts           InvestorPost[]
  pitchRequests   PitchRequest[]
  workshops       Workshop[]
}

model ProjectShowcase {
  id            String         @id @default(cuid())
  studentId     String
  title         String
  tagline       String
  description   String
  problemSolved String
  techStack     String[]
  demoUrl       String?
  pitchDeckUrl  String?
  videoUrl      String?
  marketSize    String?
  fundingNeeded String?
  isApproved    Boolean        @default(false)
  isFeatured    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  pitchRequests PitchRequest[]
  student       Student        @relation(fields: [studentId], references: [id])
}

model PitchRequest {
  id            String          @id @default(cuid())
  showcaseId    String
  investorId    String
  studentId     String
  status        PitchStatus     @default(PENDING)
  message       String?
  investorNotes String?
  scheduledAt   DateTime?
  meetingLink   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  investor      Investor        @relation(fields: [investorId], references: [id])
  showcase      ProjectShowcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  student       Student         @relation(fields: [studentId], references: [id])

  @@unique([showcaseId, investorId])
}

model Workshop {
  id            String                 @id @default(cuid())
  investorId    String
  title         String
  description   String
  date          DateTime
  duration      String
  meetingLink   String?
  maxCapacity   Int?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  investor      Investor               @relation(fields: [investorId], references: [id])
  registrations WorkshopRegistration[]
}

model WorkshopRegistration {
  id           String   @id @default(cuid())
  workshopId   String
  studentId    String
  registeredAt DateTime @default(now())
  attended     Boolean  @default(false)
  student      Student  @relation(fields: [studentId], references: [id])
  workshop     Workshop @relation(fields: [workshopId], references: [id])

  @@unique([workshopId, studentId])
}

model InvestorPost {
  id          String    @id @default(cuid())
  investorId  String
  title       String
  description String
  type        PostType  @default(FUNDING)
  deadline    DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  investor    Investor  @relation(fields: [investorId], references: [id])
}

enum UserRole {
  STUDENT
  MENTOR
  HR
  ADMIN
  INVESTOR
}

enum SubscriptionTier {
  FREE
  PRO
  PREMIUM
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  DROPPED
}

enum BatchStatus {
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
}

enum LessonType {
  VIDEO
  READING
  QUIZ
  ASSIGNMENT
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
  LATE
}

enum RecordingType {
  LIVE_SESSION
  PRE_RECORDED
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum ApplicationStatus {
  APPLIED
  REVIEWED
  SHORTLISTED
  REJECTED
  INTERVIEW_SCHEDULED
}

enum PitchStatus {
  PENDING
  REVIEWED
  ACCEPTED
  DECLINED
  SCHEDULED
  COMPLETED
}

enum PostType {
  FUNDING
  MENTORSHIP
  INCUBATION
  CHALLENGE
}
