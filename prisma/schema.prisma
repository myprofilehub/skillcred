generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth Models

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  username      String?   @unique
  mobile        String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(STUDENT)
  
  accounts      Account[]
  sessions      Session[]
  
  // Custom Domain Credentials
  lmsEmail        String?   @unique
  forcePasswordChange Boolean @default(false)

  // Preferences
  emailNotifications Boolean @default(true)
  projectUpdateNotifications Boolean @default(true)
  
  // Role specific relations
  studentProfile Student?
  mentorProfile  Mentor?
  hrProfile      HRProtocol?
  investorProfile Investor?
  
  // Common relations
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  notifications    Notification[]
  attendanceRecords AttendanceRecord[]
  payments         Payment[]    // New relation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  STUDENT
  MENTOR
  HR
  INVESTOR
  ADMIN
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------------------------------------------------------
// STUDENT & MENTOR PROFILES
// -----------------------------------------------------------------------------

model Student {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  college     String?
  stream      String?
  year        String?
  bio         String?
  githubUrl   String?
  linkedinUrl String?
  
  patEligible Boolean @default(false)
  
  // Relationships
  
  attendedWorkshops WorkshopRegistration[]
  
  enrollments      Enrollment[]
  assignments      ProjectAssignment[]
  assessmentResults Result[]
  portfolio        Portfolio?
  lessonProgress   LessonProgress[]
  
  // Subscription
  subscription SubscriptionTier @default(FREE)

  // HR Visibility
  hrVisibile       Boolean @default(false)
  hrViews          HRView[]
  interviewRequests InterviewRequest[]
  jobApplications  JobApplication[]
  
  // Investor Connect
  projectShowcases ProjectShowcase[]
  pitchRequests    PitchRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionTier {
  FREE
  PRO
  PREMIUM
}

model Mentor {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  specialization String?
  bio            String?
  availability   String?  // Could be JSON or specialized structure later
  
  // Relationships
  assignedStudents Enrollment[] @relation("MentorEnrollments")
  leadingTracks    Track[]      @relation("TrackLead")
  batches          Batch[]      // New relation
  reviews          Review[]
  sessions         MentorshipSession[]
  recommendations  Recommendation[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HRProtocol {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  company     String
  position    String
  
  viewedProfiles HRView[]
  interviewRequests InterviewRequest[]
  jobs        Job[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// CORE ACADEMIC MODELS (TRACKS / STREAMS)
// -----------------------------------------------------------------------------

model Track {
  id          String   @id @default(cuid())
  title       String   
  slug        String   @unique // e.g., 'ai-ml', 'full-stack'
  description String
  icon        String?  
  
  projects    Project[]
  students    Enrollment[]
  assessments Assessment[]
  courses     Course[] // A track can have multiple courses (LMS)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  recordings  Recording[]
  
  defaultMentorId String?
  defaultMentor   Mentor? @relation("TrackLead", fields: [defaultMentorId], references: [id])
  curriculumPhases    CurriculumPhase[]
  
  // Curriculum
  catalogProjects     ProjectCatalogItem[]
  batches             Batch[]      // New relation
}

model CurriculumPhase {
  id          String   @id @default(cuid())
  trackId     String
  track       Track    @relation(fields: [trackId], references: [id])
  phaseNumber Int      // 1–8
  title       String   // e.g., "Discovery & Setup"
  weekStart   Int      // Week 1
  weekEnd     Int      // Week 1
  description String?
  
  sessions    CurriculumSession[]
  
  @@unique([trackId, phaseNumber])
}

model CurriculumSession {
  id            String   @id @default(cuid())
  phaseId       String
  phase         CurriculumPhase @relation(fields: [phaseId], references: [id])
  sessionNumber Int      // 1–48
  title         String
  objectives    String[] // Learning objectives
  activities    String[] // Hands-on activities
  deliverables  String[] // Session deliverables
  keyTech       String[] // Key technologies
  duration      Int      @default(120) // minutes
  
  @@unique([phaseId, sessionNumber])
}

model ProjectCatalogItem {
  id              String   @id @default(cuid())
  trackId         String
  track           Track    @relation(fields: [trackId], references: [id])
  
  name            String   // e.g., "ShopSync"
  tagline         String   // One-liner
  description     String?  @db.Text
  difficulty      Int      @default(2) // 1=⭐, 2=⭐⭐, 3=⭐⭐⭐
  coreFeatures    String[] // Core feature list
  conceptsCovered Json?    // Phase-mapped concept coverage (P1-P8 mapping)
  startupAngle    String?  // Startup potential description
  
  isActive        Boolean  @default(true)
  addedBy         String?  // Admin/Mentor who added it
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  batches         Batch[]
  assignments     ProjectAssignment[]  // Track progress via Classroom assignments
}

model Enrollment {
  id        String   @id @default(cuid())
  studentId String
  trackId   String
  mentorId  String?
  status    EnrollmentStatus @default(ACTIVE)
  progress  Int      @default(0) // Percentage calculated from projects/courses
  programDuration String @default("8-week") // 4-week or 8-week
  couponCode      String?  // Early bird, partner codes, etc.
  
  student   Student  @relation(fields: [studentId], references: [id])
  track     Track    @relation(fields: [trackId], references: [id])
  mentor    Mentor?  @relation("MentorEnrollments", fields: [mentorId], references: [id])
  
  certIssued Boolean @default(false)
  certUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Enrollment & Batching
  batchId   String?
  batch     Batch?   @relation(fields: [batchId], references: [id])
  
  @@unique([studentId, trackId])
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  DROPPED
}

// -----------------------------------------------------------------------------
// BATCH & PAYMENT MODULE (NEW)
// -----------------------------------------------------------------------------

model Batch {
  id              String   @id @default(cuid())
  trackId         String
  track           Track    @relation(fields: [trackId], references: [id])
  
  // A batch is specific to a project in the new design
  projectId       String
  project         ProjectCatalogItem @relation(fields: [projectId], references: [id])
  
  mentorId        String?
  mentor          Mentor?  @relation(fields: [mentorId], references: [id])
  
  students        Enrollment[]
  
  name            String   // e.g., "AI-Chatbot-B1"
  status          BatchStatus @default(OPEN) 
  
  maxStudents     Int      @default(20)
  startDate       DateTime?
  endDate         DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum BatchStatus {
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  amount          Float
  currency        String   @default("INR")
  status          PaymentStatus @default(PENDING)
  provider        String   @default("RAZORPAY") // RAZORPAY, MANUAL
  transactionId   String?  // External ID from Razorpay
  
  // Metadata for what was bought
  trackId         String?
  projectId       String?
  batchId         String?
  programDuration String?
  couponCode      String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// -----------------------------------------------------------------------------
// PROJECT MANAGEMENT
// -----------------------------------------------------------------------------

model Project {
  id          String   @id @default(cuid())
  trackId     String
  track       Track    @relation(fields: [trackId], references: [id])
  
  title       String
  description String
  level       String   // Beginner, Intermediate, Advanced, Capstone
  order       Int      // 1, 2, 3...
  
  skills      String[]
  
  assignments ProjectAssignment[]
  portfolioItems PortfolioProject[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectAssignment {
  id          String   @id @default(cuid())
  studentId   String
  projectId   String
  catalogProjectId String?  // Links to curriculum ProjectCatalogItem
  status      ProjectStatus @default(NOT_STARTED)
  
  student     Student  @relation(fields: [studentId], references: [id])
  project     Project  @relation(fields: [projectId], references: [id])
  catalogProject ProjectCatalogItem? @relation(fields: [catalogProjectId], references: [id])
  
  submissions Submission[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, projectId])
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
}

model Submission {
  id           String   @id @default(cuid())
  assignmentId String
  githubLink   String?
  files        String?  // JSON or CSV of file URLs
  notes        String?
  
  assignment   ProjectAssignment @relation(fields: [assignmentId], references: [id])
  reviews      Review[]
  
  createdAt    DateTime @default(now())
}

model Review {
  id           String   @id @default(cuid())
  submissionId String
  mentorId     String
  verified     Boolean
  feedback     String?
  rating       Int?     // 1-5
  
  submission   Submission @relation(fields: [submissionId], references: [id])
  mentor       Mentor     @relation(fields: [mentorId], references: [id])
  
  createdAt    DateTime @default(now())
}

// -----------------------------------------------------------------------------
// LMS MODULE
// -----------------------------------------------------------------------------

model Course {
  id          String   @id @default(cuid())
  trackId     String
  track       Track    @relation(fields: [trackId], references: [id])
  title       String
  description String?
  
  modules     CourseModule[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CourseModule {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  title       String
  order       Int
  
  lessons     Lesson[]
}

model Lesson {
  id          String   @id @default(cuid())
  moduleId    String
  module      CourseModule @relation(fields: [moduleId], references: [id])
  title       String
  type        LessonType // VIDEO, READING, QUIZ
  contentUrl  String?
  duration    Int?     // in minutes
  
  progress    LessonProgress[]
}

enum LessonType {
  VIDEO
  READING
  QUIZ
  ASSIGNMENT
}

model LessonProgress {
  id          String   @id @default(cuid())
  lessonId    String
  studentId   String // Actually User ID usually, but sticking to Student model here for consistency with other modules? 
                       // Usually LMS progress is tied to User. Let's link to Student model for consistency in this system.
  completed   Boolean @default(false)
  
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
  // student     Student  @relation(fields: [studentId], references: [id]) 
  // Simplified: just store ID for now or link to Enrollment if needed. 
  // Let's go with linking to User or Student. Linking to User is safer for LMS but here Student makes sense.
  // Actually, User is better for authentication context. But let's stick to Student ID for strict separation.
  // Wait, I didn't add the relation field in Student model to LessonProgress.
  // I will skip the relation field in Student for now to avoid clutter, or add it.
  // Let's add relationships properly.
  // enrollment seems the best place to aggregate progress.
  // For granular progress:
  // Let's actually link to Enrollment? No, LessonProgress is per student.
  student     Student @relation(fields: [studentId], references: [id])

  updatedAt   DateTime @updatedAt

  @@unique([studentId, lessonId])
}

// -----------------------------------------------------------------------------
// MENTOR INTERACTION
// -----------------------------------------------------------------------------

model MentorshipSession {
  id          String   @id @default(cuid())
  mentorId    String
  studentId   String? // Nullable if it's an open slot? Or only booked sessions. Let's say Booked.
  startTime   DateTime
  endTime     DateTime
  status      SessionStatus @default(SCHEDULED)
  meetingLink String?
  
  mentor      Mentor   @relation(fields: [mentorId], references: [id])
  // student     Student? @relation(fields: [studentId], references: [id]) 
  // Avoiding circular dependency issues or too many relations on Student. 
  // Let's just keep it simple.
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  content     String
  read        Boolean  @default(false)
  
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String
  read        Boolean  @default(false)
  type        String?  // 'info', 'success', 'warning', 'error'
  link        String?
  
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
}

// -----------------------------------------------------------------------------
// ASSESSMENT MODULE
// -----------------------------------------------------------------------------

model Assessment {
  id          String   @id @default(cuid())
  trackId     String
  track       Track    @relation(fields: [trackId], references: [id])
  title       String
  type        String   // MCQ, CODING, VIVA
  totalMarks  Int
  passingMarks Int
  
  results     Result[]
  
  createdAt   DateTime @default(now())
}

model Result {
  id            String   @id @default(cuid())
  assessmentId  String
  studentId     String
  score         Int
  passed        Boolean
  feedback      String?
  
  assessment    Assessment @relation(fields: [assessmentId], references: [id])
  student       Student    @relation(fields: [studentId], references: [id])
  
  createdAt     DateTime @default(now())
}

// -----------------------------------------------------------------------------
// PORTFOLIO & HR MODULE
// -----------------------------------------------------------------------------

model Portfolio {
  id          String   @id @default(cuid())
  studentId   String   @unique
  student     Student  @relation(fields: [studentId], references: [id])
  
  headline    String?
  bio         String?  // Short bio / summary
  skills      String[]
  resumeUrl   String?
  linkedinUrl String?
  githubUrl   String?
  
  experience  Json?    // Array of { title, company, startDate, endDate, description }
  education   Json?    // Array of { school, degree, year, field }
  
  publicSlug  String?  @unique
  isUnlocked  Boolean  @default(false)
  isPublic    Boolean  @default(false)
  patPassedAt DateTime?
  
  projects    PortfolioProject[]
  recommendations Recommendation[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortfolioProject {
  id          String   @id @default(cuid())
  portfolioId String
  
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])
  
  // Optional link to platform project
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  
  title       String
  description String
  imageUrl    String?
  projectUrl  String?
  githubUrl   String?
  skills      String[]

  verifiedBy  String? // Mentor ID
  grade       Int?
  feedback    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Recommendation {
  id          String   @id @default(cuid())
  portfolioId String
  mentorId    String
  content     String?  @db.Text
  fileUrl     String?  // URL to the storage location (e.g., Drive link or S3)
  
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])
  mentor      Mentor    @relation(fields: [mentorId], references: [id])
  
  issuedAt    DateTime @default(now())
}

model HRView {
  id          String   @id @default(cuid())
  hrId        String
  studentId   String
  viewedAt    DateTime @default(now())
  
  hr          HRProtocol @relation(fields: [hrId], references: [id])
  student     Student    @relation(fields: [studentId], references: [id])
}

model InterviewRequest {
  id          String   @id @default(cuid())
  hrId        String
  studentId   String
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  message     String?
  
  hr          HRProtocol @relation(fields: [hrId], references: [id])
  student     Student    @relation(fields: [studentId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// GOOGLE INTEGRATION
// -----------------------------------------------------------------------------

model GoogleClassroom {
  id             String   @id @default(cuid())
  googleCourseId String   @unique
  meetLink       String
  mentorId       String
  
  updatedAt      DateTime @updatedAt
  
  recordings     Recording[]
  attendanceSessions AttendanceSession[]
}

model AttendanceSession {
  id              String   @id @default(cuid())
  googleCourseId  String
  
  // Link to our local GoogleClassroom model if it exists, but verification 
  // might happen for courses not fully synced yet.
  // Ideally, link to GoogleClassroom.
  googleClassroom   GoogleClassroom? @relation(fields: [googleClassroomId], references: [id])
  googleClassroomId String?

  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  
  meetCode        String?
  
  verifiedBy      String   // Mentor ID (User ID)
  
  records         AttendanceRecord[]
  
  createdAt       DateTime @default(now())

  @@unique([googleCourseId, startTime]) // Prevent duplicate verification of same session
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  sessionId   String
  studentId   String   // User ID of the student
  status      AttendanceStatus @default(PRESENT)
  
  session     AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student     User     @relation(fields: [studentId], references: [id])
  
  createdAt   DateTime @default(now())
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
  LATE
}

model Recording {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String
  type        RecordingType
  
  // For Live Sessions (Auto-synced or manually linked to a class)
  meetCode    String?
  googleClassroomId String?
  googleClassroom   GoogleClassroom? @relation(fields: [googleClassroomId], references: [id])
  
  // For Pre-recorded Lessons (Library)
  trackId     String?
  track       Track? @relation(fields: [trackId], references: [id])
  
  isPublic    Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum RecordingType {
  LIVE_SESSION
  PRE_RECORDED
}

// -----------------------------------------------------------------------------
// JOB POSTING MODULE
// -----------------------------------------------------------------------------

model Job {
  id          String   @id @default(cuid())
  hrId        String
  hr          HRProtocol @relation(fields: [hrId], references: [id])
  
  title       String
  description String   @db.Text
  location    String
  type        JobType  @default(FULL_TIME)
  skills      String[]
  salary      String?
  
  isActive    Boolean  @default(true)
  
  applications JobApplication[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

model JobApplication {
  id          String   @id @default(cuid())
  jobId       String
  studentId   String
  status      ApplicationStatus @default(APPLIED)
  coverLetter String?  @db.Text
  
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([jobId, studentId])
}

enum ApplicationStatus {
  APPLIED
  REVIEWED
  SHORTLISTED
  REJECTED
  INTERVIEW_SCHEDULED
}

// -----------------------------------------------------------------------------
// INVESTOR MARKETPLACE
// -----------------------------------------------------------------------------

model Investor {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  company         String
  position        String
  bio             String?  @db.Text
  focusAreas      String[]   // ["AI/ML", "FinTech", "EdTech"]
  investmentRange String?    // "$50K - $500K"
  portfolioUrl    String?    // Link to portfolio/website
  linkedinUrl     String?
  
  isActive        Boolean  @default(true)
  
  pitchRequests   PitchRequest[]
  workshops       Workshop[]
  posts           InvestorPost[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProjectShowcase {
  id              String   @id @default(cuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  
  title           String
  tagline         String
  description     String   @db.Text
  problemSolved   String   @db.Text
  techStack       String[]
  demoUrl         String?
  pitchDeckUrl    String?
  videoUrl        String?
  marketSize      String?
  fundingNeeded   String?
  
  isApproved      Boolean  @default(false)  // Mentor must approve
  isFeatured      Boolean  @default(false)
  
  pitchRequests   PitchRequest[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PitchRequest {
  id              String   @id @default(cuid())
  showcaseId      String
  investorId      String
  studentId       String
  
  status          PitchStatus @default(PENDING)
  message         String?  @db.Text  // Student's pitch message
  investorNotes   String?  @db.Text  // Investor's feedback
  
  scheduledAt     DateTime?
  meetingLink     String?
  
  showcase        ProjectShowcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  investor        Investor @relation(fields: [investorId], references: [id])
  student         Student  @relation(fields: [studentId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([showcaseId, investorId])
}

enum PitchStatus {
  PENDING
  REVIEWED
  ACCEPTED
  DECLINED
  SCHEDULED
  COMPLETED
}

model Workshop {
  id              String   @id @default(cuid())
  investorId      String
  investor        Investor @relation(fields: [investorId], references: [id])
  
  title           String
  description     String   @db.Text
  date            DateTime
  duration        String
  meetingLink     String?
  maxCapacity     Int?
  
  registrations   WorkshopRegistration[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WorkshopRegistration {
  id              String   @id @default(cuid())
  workshopId      String
  studentId       String
  
  workshop        Workshop @relation(fields: [workshopId], references: [id])
  student         Student  @relation(fields: [studentId], references: [id])
  
  registeredAt    DateTime @default(now())
  attended        Boolean  @default(false)
  
  @@unique([workshopId, studentId])
}

model InvestorPost {
  id              String   @id @default(cuid())
  investorId      String
  investor        Investor @relation(fields: [investorId], references: [id])
  
  title           String
  description     String   @db.Text
  type            PostType  @default(FUNDING) // Funding, Mentorship, Incubation
  deadline        DateTime?
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum PostType {
